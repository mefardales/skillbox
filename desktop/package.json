{
  "name": "skillbox-desktop",
  "version": "0.1.0",
  "description": "Skillbox Desktop — Skill manager IDE for AI coding skills",
  "main": "src/main.js",
  "scripts": {
    "start": "node launch.js",
    "start:legacy": "node launch.js",
    "build": "electron-builder --win --mac --linux",
    "build:ui": "vite build",
    "dev": "vite build && node launch.js --dev",
    "dev:vite": "concurrently \"vite --config vite.config.js\" \"sleep 2 && node launch.js --vite\"",
    "dev:hot": "vite --config vite.config.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "Skillbox",
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "electron": "^41.0.0",
    "electron-builder": "^25.1.0",
    "vitest": "^4.1.0"
  },
  "build": {
    "appId": "io.skillbox.desktop",
    "productName": "Skillbox",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "dist-ui/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "../icon.svg"
    },
    "mac": {
      "target": "dmg",
      "icon": "../icon.svg"
    },
    "linux": {
      "target": "AppImage",
      "icon": "../icon.svg"
    }
  },
  "dependencies": {
    "@lydell/node-pty": "^1.2.0-beta.3",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@radix-ui/colors": "^3.0.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/browser": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "adm-zip": "^0.5.16",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "daisyui": "^5.5.19",
    "lucide-react": "^0.577.0",
    "monaco-editor": "^0.52.2",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-arborist": "^3.4.3",
    "react-dom": "^19.2.4",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^5.4.21",
    "zod": "^4.3.6"
  }
}
